{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-02",
                "-g",
                "-Wall",
                "-Wextra",
                "-Wno-unused-parameter",
                "-march=native",
                "-I$src",
                "$src/fluid/main.cpp",
                "$src/fluid/grid/grid.cpp",
                "$src/fluid/grid/reconstruction.cpp",
                "$src/fluid/grid/transport.cpp",
                "$src/fluid/physics/conserved.cpp",
                "$src/fluid/physics/primitive.cpp",
                "$src/fluid/physics/spacetime.cpp",
                "$src/fluid/physics/thermo.cpp",
                "$src/fluid/solver/hlld.cpp",
                "$src/fluid/solver/initconds.cpp",
                "$src/fluid/solver/integrator.cpp",
                "-I/opt/homebrew/include",
                "-I/opt/homebrew/lib",
                "-lhdf5",
                "-o",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "build-debug",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-O0",
                "-g3",
                "-fsanitize=address,undefined",
                "-fno-omit-frame-pointer",
                "-Wall",
                "-I$src",
                "$src/fluid/main.cpp",
                "$src/fluid/grid/grid.cpp",
                "$src/fluid/grid/reconstruction.cpp",
                "$src/fluid/grid/transport.cpp",
                "$src/fluid/physics/conserved.cpp",
                "$src/fluid/physics/primitive.cpp",
                "$src/fluid/physics/spacetime.cpp",
                "$src/fluid/physics/thermo.cpp",
                "$src/fluid/solver/hlld.cpp",
                "$src/fluid/solver/initconds.cpp",
                "$src/fluid/solver/integrator.cpp",
                "-I/opt/homebrew/include",
                "-I/opt/homebrew/lib",
                "-lhdf5",
                "-o",
                "$src/grmhd-debug"
            ],
            "group": "build",
            "problemMatcher" : "clang++",
        },
        {
            "label": "run",
            "type": "shell",
            "command": "src/fluid/main.cpp",
            "group": "test",
            "dependsOn": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "rm -f $src/grmhd $src/grmhd-debug",
            "group": "build"
        }
    ],
}